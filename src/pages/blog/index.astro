---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout title="博客" description="技术笔记、项目复盘与思考。">
  <section class="mx-auto max-w-5xl px-6 py-16">
    <header class="mb-12">
      <h1 class="text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl">博客</h1>
      <p class="mt-4 max-w-2xl text-lg text-[var(--color-muted)]">
        记录学习与实践过程中的想法与总结。
      </p>
      {
        allTags.length > 0 && (
          <ul class="mt-6 flex flex-wrap gap-2">
            {allTags.map((tag) => (
              <li class="rounded-full border border-[var(--color-border)] px-3 py-1 text-sm text-slate-600">
                {tag}
              </li>
            ))}
          </ul>
        )
      }
    </header>

    {
      posts.length > 0 ? (
        <div class="grid gap-6 sm:grid-cols-2">
          {posts.map((post) => (
            <BlogCard post={post} />
          ))}
        </div>
      ) : (
        <p class="text-[var(--color-muted)]">暂无文章，请在 src/content/blog/ 添加内容。</p>
      )
    }
  </section>
</BaseLayout>
