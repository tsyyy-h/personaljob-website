---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import BlogCard from '../components/BlogCard.astro';
import { siteConfig } from '../site.config';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .slice(0, 3);

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout>
  <section class="mx-auto max-w-5xl px-6 py-20 sm:py-28">
    <div class="flex flex-col items-start gap-8 sm:flex-row sm:items-center sm:gap-12">
      <div class="flex h-24 w-24 shrink-0 items-center justify-center rounded-full bg-[var(--color-surface)] text-3xl font-semibold text-slate-400 ring-2 ring-[var(--color-border)]">
        {siteConfig.name.charAt(0)}
      </div>
      <div>
        <h1 class="text-4xl font-semibold tracking-tight text-slate-900 sm:text-5xl">
          你好，我是 {siteConfig.name}
        </h1>
        <p class="mt-4 max-w-2xl text-lg leading-relaxed text-[var(--color-muted)]">
          {siteConfig.description}
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href="/projects"
            class="inline-flex items-center rounded-lg bg-[var(--color-accent)] px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-[var(--color-accent-hover)]"
          >
            查看作品集
          </a>
          <a
            href="/blog"
            class="inline-flex items-center rounded-lg border border-[var(--color-border)] px-5 py-2.5 text-sm font-medium text-slate-700 transition-colors hover:border-slate-300 hover:bg-[var(--color-surface)]"
          >
            阅读博客
          </a>
        </div>
      </div>
    </div>
  </section>

  {
    featuredProjects.length > 0 && (
      <section class="mx-auto max-w-5xl px-6 py-16">
        <div class="mb-8 flex items-end justify-between">
          <h2 class="text-2xl font-semibold tracking-tight text-slate-900">精选项目</h2>
          <a
            href="/projects"
            class="text-sm font-medium text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors"
          >
            查看全部 →
          </a>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {featuredProjects.map((project) => (
            <ProjectCard project={project} />
          ))}
        </div>
      </section>
    )
  }

  {
    latestPosts.length > 0 && (
      <section class="mx-auto max-w-5xl px-6 py-16">
        <div class="mb-8 flex items-end justify-between">
          <h2 class="text-2xl font-semibold tracking-tight text-slate-900">最新文章</h2>
          <a
            href="/blog"
            class="text-sm font-medium text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors"
          >
            查看全部 →
          </a>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {latestPosts.map((post) => (
            <BlogCard post={post} />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
